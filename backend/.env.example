PORT=5000
# IMPORTANT: When running locally use 127.0.0.1
# When running with docker-compose, use 'mongodb' as the host instead of 127.0.0.1
# Example: MONGODB_URI=mongodb://mongodb:27017/lost-and-found
MONGODB_URI=mongodb://127.0.0.1:27017/lost-and-found
JWT_SECRET=your_jwt_secret_here_make_it_secure
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
